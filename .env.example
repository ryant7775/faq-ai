# Public URL of the deployed app (used by external callers such as Supabase Edge Functions).
# Example: https://your-app.up.railway.app
SHOPIFY_APP_HOST=

# Shared secret for server-to-server sync endpoints (must match Supabase Edge Function secrets).
WEBHOOK_SECRET=

# Supabase project: https://iepsllggdll.supabase.co
SUPABASE_URL=

# Service role key for optional published_pages metadata write-back.
SUPABASE_SERVICE_ROLE_KEY=
